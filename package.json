{
  "name": "duetto",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev -w @duetto/admin",
    "dev:backend": "npm run dev -w @duetto/backend",
    "dev:teacher": "npm run start -w @duetto/teacher-mobile",
    "dev:student": "npm run start -w @duetto/student-mobile",
    "db:generate": "npm run db:generate -w @duetto/backend",
    "db:migrate": "npm run db:migrate -w @duetto/backend",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "overrides": {
    "react-native-screens": "4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "expo-image-picker": "~16.0.6"
  }
}
