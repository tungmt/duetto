DATABASE_URL="postgresql://duetto:duetto@localhost:5432/duetto?schema=public"

# AWS (SES + S3)
AWS_REGION="ap-southeast-1"
AWS_SES_FROM_EMAIL="no-reply@mindenglish.vn"
AWS_SES_FROM_NAME="Mindenglish"
AWS_S3_BUCKET="mindenglish"
# Required for this setup (env-based credentials)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional temporary token (STS)
AWS_SESSION_TOKEN=""
# Optional CDN/custom domain. If empty, S3 URL is used.
AWS_S3_PUBLIC_BASE_URL=""
